      <aliases enabled='yes' />
      <column caption='Age Group' datatype='string' name='[Calculation_1098437326729216]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if [person_age] &gt;=18 and [person_age] &lt;=25 then &apos;18-25&apos;&#13;&#10;ELSEIF [person_age] &gt;=26 and [person_age] &lt;=35 then &apos;26-35&apos;&#13;&#10;ELSEIF [person_age] &gt;=36 and [person_age] &lt;=45 then &apos;36-45&apos;&#13;&#10;ELSEIF [person_age] &gt;=46 and [person_age] &lt;=55 then &apos;46-55&apos;&#13;&#10;ELSE &apos;56+&apos;&#13;&#10;END' />
      </column>
      <column caption='Credit Score Category' datatype='string' name='[Calculation_1098437331943425]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [credit_score] &lt; 600 then &apos;Poor&apos;&#13;&#10;ELSEIF [credit_score] &gt;=600 AND [credit_score] &lt; 700 THEN &apos;Fair&apos;&#13;&#10;ELSEIF [credit_score] &gt;=700 AND [credit_score] &lt; 750 THEN &apos;Good&apos;&#13;&#10;ELSE &apos;Excellent&apos;&#13;&#10;END' />
      </column>
      <column caption='Total Loan Amount' datatype='real' default-format='c&quot;₹ &quot;#,##0&quot;M&quot;;&quot;₹ &quot;-#,##0&quot;M&quot;' name='[Calculation_1098437355446274]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([loan_amnt])/1000000' />
      </column>
